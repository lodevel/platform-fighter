{
  "name": "platform-fighter",
  "version": "0.1.0",
  "description": "A Smash Bros-style 2D platform fighter built with Phaser 3 + Matter.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run build:palettes",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "palette-swap": "tsx scripts/palette-swap/index.ts",
    "build:palettes": "tsx scripts/palette-swap/index.ts",
    "validate:characters": "tsx scripts/validate-character-data.ts"
  },
  "keywords": [
    "phaser",
    "matter-js",
    "platform-fighter",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
